rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Skeleton rules for API-first architecture.
    // TODO: Replace with strict member/admin checks.

    match /members/{uid} {
      allow read, write: if false;
    }

    match /presentations/{id} {
      allow read, write: if false;
    }

    match /events/{id} {
      allow read, write: if false;
    }

    match /teaParties/{id} {
      allow read, write: if false;
    }

    match /settings/grades {
      allow read, write: if false;
    }

    match /settings/presentationTypes {
      allow read, write: if false;
    }

    match /settings/groups {
      allow read, write: if false;
    }

    match /settings/colors {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

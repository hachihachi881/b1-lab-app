rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理者コレクション：ログイン済みユーザーは読み取り可能
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if false; // Firebaseコンソールからのみ編集可能
    }
    
    // 投稿（予定）：誰でも読み取り可能、ログイン済みユーザーのみ書き込み可能
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // お茶会情報：誰でも読み取り可能、管理者のみ書き込み可能
    match /teaParties/{docId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    
    // 設定情報（お茶会など）：誰でも読み取り可能、ログイン済みユーザーのみ書き込み可能
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // ユーザー情報：ログイン済みユーザーは読み取り可能、自分の情報のみ書き込み可能
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // デフォルト：その他のコレクションは拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
